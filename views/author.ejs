<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
      integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="../main.css" />
    <title>Portfolio</title>
  </head>
  <body>
    <div class="frame">
      <div class="main_frame">
        <div class="left_frame">
          <div class="left_1">
            <div class="left_1-1">
              <img
                src="images/profile.png"
                width="156px"
                height="142px"
                alt=""
              />
            </div>
            <div class="left_1-2"><%=user.name%></div>
            <div class="left_1-3"><%=user.profession%></div>
            <div class="left_icons">
              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Facebook.svg" class="icon-1" />
                </div>
              </a>

              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Instagram.svg" class="icon-1" />
                </div>
              </a>

              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Twitter.svg" class="icon-1" />
                </div>
              </a>

              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Linkeding.svg" class="icon-1" />
                </div>
              </a>

              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Youtube.svg" class="icon-1" />
                </div>
              </a>

              <a class="link_href" href="">
                <div class="icon">
                  <img src="icon/Dribbble.svg" class="icon-1" />
                </div>
              </a>
            </div>
          </div>
          <div class="marginer"></div>
          <div class="left_2">
            <div class="info">
              <p><strong>Age</strong> <span><%=user.age%></span></p>
            </div>
            <div class="info">
              <p><strong>Residence</strong> <span><%=user.residence%></span></p>
            </div>
            <div class="info">
              <p><strong>Freelance:</strong> <span>Available</span></p>
            </div>
            <div class="info">
              <p><strong>Address:</strong><span><%=user.address%></span></p>
            </div>
          </div>
          <div class="marginer"></div>
          <div class="left_3">
            <h2>Languages</h2>
            <div class="lang">
              <div class="lang_info">
                <p><%=user.languages[0]%></p>
                <span>100%</span>
              </div>
              <div class="lang_bar">
                <div class="fill" style="width: 100%"></div>
              </div>

              <div class="lang_info">
                <p><%=user.languages[1]%></p>
                <span>80%</span>
              </div>
              <div class="lang_bar2">
                <div class="fill" style="width: 80%"></div>
              </div>

              <div class="lang_info">
                <p><%=user.languages[2]%></p>
                <span>60%</span>
              </div>
              <div class="lang_bar3">
                <div class="fill" style="width: 60%"></div>
              </div>
            </div>
          </div>
          <div class="marginer"></div>
          <div class="left_4">
            <h2>Skills</h2>
            <div class="skill_info">
              <p><%=user.skills[0]%></p>
              <span>90%</span>
            </div>
            <div class="skill_bar">
              <div class="fill" style="width: 90%"></div>
            </div>

            <div class="skill_info">
              <p><%=user.skills[1]%></p>
              <span>85%</span>
            </div>
            <div class="skill_bar">
              <div class="fill" style="width: 85%"></div>
            </div>

            <div class="skill_info">
              <p><%=user.skills[2]%></p>
              <span>80%</span>
            </div>
            <div class="skill_bar">
              <div class="fill" style="width: 90%"></div>
            </div>

            <div class="skill_info">
              <p><%=user.skills[3]%></p>
              <span>75%</span>
            </div>
            <div class="skill_bar">
              <div class="fill" style="width: 75%"></div>
            </div>

            <div class="skill_info">
              <p><%=user.skills[4]%></p>
              <span>85%</span>
            </div>
            <div class="skill_bar">
              <div class="fill" style="width: 85%"></div>
            </div>
          </div>
          <div class="marginer"></div>
          <div class="left_5">
            <h2>Extra Skills</h2>
            <div class="extra_s">
              <img src="icon/ex_icon.svg" alt="" />
              <span><%=user.extra_skills[0]%></span>
            </div>

            <div class="extra_s">
              <img src="icon/ex_icon.svg" alt="" />
              <span><%=user.extra_skills[1]%></span>
            </div>

            <div class="extra_s">
              <img src="icon/ex_icon.svg" alt="" />
              <span><%=user.extra_skills[2]%></span>
            </div>

            <div class="extra_s">
              <img src="icon/ex_icon.svg" alt="" />
              <span><%=user.extra_skills[3]%></span>
            </div>
          </div>
          <div class="marginer"></div>
        </div>

        <div class="midd_frame">
          <div class="person-section">
            <div class="person-text">
              <h1>
                Doctor neurologists <br />
                in OHSU Hospital
              </h1>
              <p>
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Et,
                volutpat feugiat placerat lobortis. Natoque rutrum semper sed
                suspendisse nunc lectus.
              </p>
              <button class="person-btn">HIRE ME &rarr;</button>
            </div>

            <div class="persn_image">
              <img src="images/person.png" alt="Profile" />
            </div>

            <div class="figura1">
              <img src="icon/el.svg" alt="" />
            </div>
            <div class="figura">
              <img src="icon/el.svg" alt="" />
            </div>
            <div class="figura2">
              <img src="icon/elli.svg" alt="" />
            </div>
            <div class="figura3">
              <img src="icon/ellips.svg" alt="" />
            </div>
            <div class="figura4">
              <img src="icon/elli.svg" alt="" />
            </div>
            <div class="figura5">
              <img src="icon/rec.svg" alt="" />
            </div>
          </div>
          <div class="mid_bottom">
            <div class="bottom_info">
              <h1>My Services</h1>
              <span
                >Lorem ipsum dolor sit amet consectetur adipisicing elit. Saepe
                ipsa nostrum dignissimos numquam repellendus non minus quia
                atque vitae sint!</span
              >
            </div>
            <div class="bottom_page">
              <div class="page_part">
                <img src="icon/monitor.svg" alt="" />
                <strong>Web development</strong>
                <span>Blog, E-Commerce</span>
              </div>

              <div class="page_part">
                <img src="icon/monitor.svg" alt="" />
                <strong>uI/uX design</strong>
                <span>Mobile app, website design</span>
              </div>

              <div class="page_part">
                <img src="icon/monitor.svg" alt="" />
                <strong>sound design</strong>
                <span>Voice Over, Beat Making</span>
              </div>

              <div class="page_part">
                <img src="icon/monitor.svg" alt="" />
                <strong>game design</strong>
                <span>Character Design, Props</span>
              </div>

              <div class="page_part">
                <img src="icon/monitor.svg" alt="" />
                <strong>photography</strong>
                <span>portrait, product photography</span>
              </div>

              <div class="page_part">
                <strong> advertising</strong>
                <span
                  >Lorem ipsum dolor sit amet, consectetur adipiscing elit.
                  Vitae nulla diam in ac dictum a urna viverra morbi.</span
                >

                <a href=""> <h3 style="color: #ffb400">Order Now ></h3></a>
              </div>
            </div>
          </div>
        </div>

        <div class="right_frame">
          <div class="container">
            <a href=""><img src="icon/Contrast.svg" alt="" /></a>
          </div>
          <div class="contr">
            <div class="fon">
              <a href=""><img src="icon/Home.svg" alt="" class="image" /></a>
            </div>
          </div>

          <div class="fon">
            <a href=""><img src="icon/list.svg" alt="" class="image" /></a>
          </div>

          <div class="fon">
            <a href=""><img src="icon/student.svg" alt="" class="image" /></a>
          </div>

          <div class="fon">
            <a href=""><img src="icon/case.svg" alt="" class="image" /></a>
          </div>

          <div class="fon">
            <a href=""><img src="icon/kv.svg" alt="" class="image" /></a>
          </div>

          <div class="fon">
            <a href=""><img src="icon/message.svg" alt="" class="image" /></a>
          </div>
        </div>
      </div>
    </div>
  </body>
</html>
